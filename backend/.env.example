# Copy this file to .env and fill in your values.
# Never commit the actual .env file.

# Application
APP_NAME="PharmSense API"
APP_ENV=development          # development | staging | production
DEBUG=true

# Database
# SQLite (default for local dev) — just a file path, no server needed.
# To switch to PostgreSQL, change this to:
#   postgresql+psycopg2://user:password@host:5432/pharmsense
DATABASE_URL=sqlite:///./pharmsense.db

# Security
# Generate a strong random key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_STRONG_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# Seed admin user (created automatically on first startup)
FIRST_ADMIN_EMAIL=admin@pharmsense.dev
FIRST_ADMIN_PASSWORD=admin123       # Change before any real deployment!

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
